{
  "name": "@indian-property-calc/backend",
  "version": "1.0.0",
  "description": "Backend for Indian Property Calculator",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.cjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/data/seedData.ts",
    "db:init": "tsx src/scripts/initDb.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "ioredis": "^5.3.2",
    "sqlite3": "^5.1.7",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "uuid": "^11.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2"
  }
}
