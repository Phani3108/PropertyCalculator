{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Property Rule Schema",
  "type": "object",
  "required": [
    "region",
    "property_types",
    "stamp_duty",
    "registration_fee",
    "gst_applicable",
    "loan",
    "last_verified",
    "source",
    "updated_by"
  ],
  "properties": {
    "region": { "type": "string" },
    "property_types": { "type": "array", "items": { "type": "string", "enum": ["flat", "house", "land", "villa"] }, "minItems": 1 },
    "stamp_duty": { "type": "number", "minimum": 0, "maximum": 1 },
    "female_rebate": { "type": "number", "minimum": 0, "maximum": 1 },
    "registration_fee": { "type": "number", "minimum": 0, "maximum": 1 },
    "permit_fee": { "type": "number", "minimum": 0 },
    "gst_applicable": { "type": "boolean" },
    "subsidies": { "type": "array", "items": { "type": "object", "required": ["name", "eligibility", "value"], "properties": { "name": { "type": "string" }, "eligibility": { "type": "string" }, "value": { "type": "string" } } } },
    "loan": { "type": "object", "required": ["max_ltv", "interest_rate", "tenure_years"], "properties": { "max_ltv": { "type": "number", "minimum": 0, "maximum": 1 }, "interest_rate": { "type": "number", "minimum": 0, "maximum": 1 }, "tenure_years": { "type": "integer", "minimum": 1 } } },
    "freehold_allowed": { "type": "boolean" },
    "last_verified": { "type": "string", "format": "date" },
    "source": { "type": "string", "format": "uri" },
    "updated_by": { "type": "string" },
    "notes": { "type": "string" },
    "data_version": { "type": "string" }
  },
  "additionalProperties": false
}

